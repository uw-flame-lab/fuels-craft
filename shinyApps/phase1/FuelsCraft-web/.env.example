# FuelsCraft-web Environment Configuration
# Copy this to .env and customize for your environment

# Node Environment
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# FastFuels API Configuration
FASTFUELS_API_URL=https://api.fastfuels.silvxlabs.com/v1
FASTFUELS_API_KEY=your_api_key_here

# React App Configuration (used during build)
REACT_APP_API_BASE_URL=http://localhost:3001

# Optional: HTTPS
# SSL_CERT_PATH=/etc/certs/cert.pem
# SSL_KEY_PATH=/etc/certs/key.pem

# Optional: Logging
# LOG_FILE=/var/log/fuels-craft/app.log

# Optional: Database (if needed in future)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fuels_craft
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# Optional: File Upload
# UPLOAD_DIR=/var/uploads/fuels-craft
# MAX_FILE_SIZE=104857600  # 100MB

# Optional: Monitoring
# SENTRY_DSN=
# NEW_RELIC_LICENSE_KEY=
